{
  "version": 2,
  "crons": [
    {
      "path": "/api/keep-alive",
      "schedule": "0 0 * * *"
    }
  ],
  "builds": [
    {
      "src": "Backend/api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "rewrites": [
    {
      "source": "/api/python/(.*)",
      "destination": "Backend/api/index.py"
    }
  ]
}
